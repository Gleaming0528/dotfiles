# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Host 10.50.0.50
  HostName 10.50.0.50
  Port 32309
  User root

Host 1.117.135.36
  HostkeyAlgorithms +ssh-rsa
  PubkeyAcceptedAlgorithms +ssh-rsa
  SetEnv LC_ALL=en_US.UTF-8
